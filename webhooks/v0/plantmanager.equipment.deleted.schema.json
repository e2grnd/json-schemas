{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/webhooks/v0/plantmanager.equipment.deleted.schema.json",
  "title": "plantmanager.equipment.deleted data",
  "description": "Data payload for the plantmanager.equipment.deleted event, emitted when an equipment record is deleted from PlantManager.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": [
        "string",
        "null"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "AirCooler",
        "Boiler",
        "Compressor",
        "FiredHeater",
        "HorizontalVessel",
        "PipingSystem",
        "PressureReliefDevice",
        "Pump",
        "ShellTubeHeatExchanger",
        "Sphere",
        "StorageTank",
        "VerticalVessel",
        "Other"
      ],
      "x-enum-map": {
        "AirCooler": 1,
        "Boiler": 2,
        "Compressor": 3,
        "FiredHeater": 4,
        "HorizontalVessel": 5,
        "PipingSystem": 6,
        "PressureReliefDevice": 7,
        "Pump": 8,
        "ShellTubeHeatExchanger": 9,
        "Sphere": 10,
        "StorageTank": 11,
        "VerticalVessel": 12,
        "Other": 13
      }
    },
    "unitId": {
      "type": "string",
      "format": "uuid"
    },
    "serviceStatus": {
      "type": "string",
      "enum": [
        "InService",
        "OutOfService",
        "Decommissioned"
      ],
      "x-enum-map": {
        "InService": 1,
        "OutOfService": 2,
        "Decommissioned": 3
      }
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
