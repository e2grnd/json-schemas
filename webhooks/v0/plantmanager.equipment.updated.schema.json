{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/webhooks/v0/plantmanager.equipment.updated.schema.json",
  "title": "plantmanager.equipment.updated data",
  "description": "Data payload for the plantmanager.equipment.updated event, emitted when an equipment record is modified in PlantManager. Contains a full snapshot of the equipment after the update.",
  "type": "object",
  "additionalProperties": false,
  "required": ["equipment", "links"],
  "properties": {
    "equipment": {
      "$ref": "https://e2grnd.github.io/json-schemas/plantmanager/v0/equipment-dto.schema.json",
      "description": "The equipment record as returned by the hub API (post-update snapshot)."
    },
    "links": {
      "type": "object",
      "description": "Related resource URIs.",
      "required": ["self"],
      "additionalProperties": false,
      "properties": {
        "self": {
          "type": "string",
          "format": "uri",
          "description": "URI of this equipment record in PlantManager."
        },
        "unit": {
          "type": "string",
          "format": "uri",
          "description": "URI of the parent unit."
        },
        "plant": {
          "type": "string",
          "format": "uri",
          "description": "URI of the parent plant."
        }
      }
    }
  }
}
