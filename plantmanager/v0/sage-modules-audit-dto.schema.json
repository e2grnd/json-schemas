{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/sage-modules-audit-dto.schema.json",
  "title": "SageModulesAuditDto",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "sageModuleId": {
      "type": "string",
      "format": "uuid"
    },
    "action": {
      "enum": [
        "Add",
        "Update",
        "Copy",
        "Import",
        "UpgradeVersion",
        "Rename",
        "Share",
        "Move"
      ],
      "type": "string",
      "x-enum-map": {
        "Add": 1,
        "Update": 2,
        "Copy": 3,
        "Import": 4,
        "UpgradeVersion": 5,
        "Rename": 6,
        "Share": 7,
        "Move": 8
      }
    },
    "user": {
      "type": [
        "string",
        "null"
      ]
    },
    "logTime": {
      "type": "string",
      "format": "date-time"
    }
  }
}
