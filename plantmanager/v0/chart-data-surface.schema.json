{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/chart-data-surface.schema.json",
  "title": "ChartDataSurface",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "path": {
      "type": [
        "string",
        "null"
      ]
    },
    "parentPath": {
      "type": [
        "string",
        "null"
      ]
    },
    "groupName": {
      "type": [
        "string",
        "null"
      ]
    },
    "scaleTypeX": {
      "enum": [
        "Log",
        "Linear"
      ],
      "type": "string",
      "x-enum-map": {
        "Log": 0,
        "Linear": 1
      }
    },
    "chartType": {
      "enum": [
        "Bar",
        "Line",
        "Pie",
        "Scatter",
        "Surface"
      ],
      "type": "string",
      "x-enum-map": {
        "Bar": 0,
        "Line": 1,
        "Pie": 2,
        "Scatter": 3,
        "Surface": 4
      }
    },
    "axisType": {
      "enum": [
        "Numeric",
        "DateNumeric"
      ],
      "type": "string",
      "x-enum-map": {
        "Numeric": 0,
        "DateNumeric": 1
      }
    },
    "cloneNumber": {
      "type": "integer",
      "format": "int32"
    },
    "chartSeriesData": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "defaultConfig": {
            "type": "object",
            "properties": {
              "visible": {
                "type": "boolean"
              },
              "showInLegend": {
                "type": "boolean"
              },
              "color": {
                "type": "object",
                "properties": {
                  "r": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "g": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "b": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "a": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "isKnownColor": {
                    "type": "boolean"
                  },
                  "isEmpty": {
                    "type": "boolean"
                  },
                  "isNamedColor": {
                    "type": "boolean"
                  },
                  "isSystemColor": {
                    "type": "boolean"
                  },
                  "name": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                },
                "additionalProperties": false
              },
              "title": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          },
          "points": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "object",
              "properties": {
                "x": {
                  "type": "number",
                  "format": "double"
                },
                "y": {
                  "type": "number",
                  "format": "double"
                },
                "z": {
                  "type": "number",
                  "format": "double"
                }
              },
              "additionalProperties": false
            }
          },
          "minX": {
            "type": "number",
            "format": "double"
          },
          "maxX": {
            "type": "number",
            "format": "double"
          },
          "minY": {
            "type": "number",
            "format": "double"
          },
          "maxY": {
            "type": "number",
            "format": "double"
          },
          "minZ": {
            "type": "number",
            "format": "double"
          },
          "maxZ": {
            "type": "number",
            "format": "double"
          },
          "surfaceCells": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "enum": [
                    "Quadrilateral",
                    "Triangle",
                    "Functional"
                  ],
                  "type": "string",
                  "x-enum-map": {
                    "Quadrilateral": 0,
                    "Triangle": 1,
                    "Functional": 2
                  }
                },
                "pointIds": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "type": "integer",
                    "format": "int32"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "displacementPoints": {
            "type": [
              "array",
              "null"
            ]
          },
          "scalars": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "object",
              "properties": {
                "data": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "type": "number",
                    "format": "double"
                  }
                },
                "count": {
                  "type": "integer",
                  "format": "int32"
                }
              },
              "additionalProperties": false
            }
          },
          "yCount": {
            "type": "integer",
            "format": "int32"
          },
          "xCount": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    },
    "defaultOptions": {
      "type": "object",
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "subTitle": {
          "type": [
            "string",
            "null"
          ]
        },
        "subSubTitle": {
          "type": [
            "string",
            "null"
          ]
        },
        "legendPlacementHorizontal": {
          "enum": [
            "LeftOutside",
            "Left",
            "Center",
            "Right",
            "RightOutside"
          ],
          "type": "string",
          "x-enum-map": {
            "LeftOutside": 0,
            "Left": 1,
            "Center": 2,
            "Right": 3,
            "RightOutside": 4
          }
        },
        "legendPlacementVertical": {
          "enum": [
            "TopOutside",
            "Top",
            "Center",
            "Bottom",
            "BottomOutside"
          ],
          "type": "string",
          "x-enum-map": {
            "TopOutside": 0,
            "Top": 1,
            "Center": 2,
            "Bottom": 3,
            "BottomOutside": 4
          }
        },
        "tickCountX": {
          "type": "integer",
          "format": "int32"
        },
        "tickCountY": {
          "type": "integer",
          "format": "int32"
        },
        "allowZoom": {
          "type": "boolean"
        },
        "allowScroll": {
          "type": "boolean"
        },
        "axisTitleX": {
          "type": [
            "string",
            "null"
          ]
        },
        "axisTitleY": {
          "type": [
            "string",
            "null"
          ]
        },
        "axisTitleZ": {
          "type": [
            "string",
            "null"
          ]
        },
        "displayGroupName": {
          "type": [
            "string",
            "null"
          ]
        },
        "drawGridLinesX": {
          "type": "boolean"
        },
        "drawGridLinesY": {
          "type": "boolean"
        },
        "drawGridLinesZ": {
          "type": "boolean"
        },
        "showTitle": {
          "type": "boolean"
        },
        "showAxesLabels": {
          "type": "boolean"
        },
        "showScaleBar": {
          "type": "boolean"
        },
        "showContourLines": {
          "type": "boolean"
        },
        "numberContourLines": {
          "type": "integer",
          "format": "int32"
        },
        "viewDirection": {
          "enum": [
            "Top",
            "XSide",
            "YSide",
            "Skew"
          ],
          "type": "string",
          "x-enum-map": {
            "Top": 0,
            "XSide": 1,
            "YSide": 2,
            "Skew": 3
          }
        },
        "deformationScaleFactor": {
          "type": "number",
          "format": "double"
        },
        "zoomAmount": {
          "type": "number",
          "format": "double"
        },
        "scalarDisplayOptions": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "units": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "format": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "visible": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "scalarCount": {
      "type": "integer",
      "format": "int32"
    },
    "hasScalars": {
      "type": "boolean"
    },
    "defaultScalarIndex": {
      "type": "integer",
      "format": "int32"
    }
  }
}
