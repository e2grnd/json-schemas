{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/chart-data-line.schema.json",
  "title": "ChartDataLine",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "path": {
      "type": [
        "string",
        "null"
      ]
    },
    "parentPath": {
      "type": [
        "string",
        "null"
      ]
    },
    "groupName": {
      "type": [
        "string",
        "null"
      ]
    },
    "scaleTypeX": {
      "enum": [
        "Log",
        "Linear"
      ],
      "type": "string",
      "x-enum-map": {
        "Log": 0,
        "Linear": 1
      }
    },
    "chartType": {
      "enum": [
        "Bar",
        "Line",
        "Pie",
        "Scatter",
        "Surface"
      ],
      "type": "string",
      "x-enum-map": {
        "Bar": 0,
        "Line": 1,
        "Pie": 2,
        "Scatter": 3,
        "Surface": 4
      }
    },
    "axisType": {
      "enum": [
        "Numeric",
        "DateNumeric"
      ],
      "type": "string",
      "x-enum-map": {
        "Numeric": 0,
        "DateNumeric": 1
      }
    },
    "cloneNumber": {
      "type": "integer",
      "format": "int32"
    },
    "chartSeriesData": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "defaultConfig": {
            "type": "object",
            "properties": {
              "visible": {
                "type": "boolean"
              },
              "showInLegend": {
                "type": "boolean"
              },
              "color": {
                "type": "object",
                "properties": {
                  "r": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "g": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "b": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "a": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "isKnownColor": {
                    "type": "boolean"
                  },
                  "isEmpty": {
                    "type": "boolean"
                  },
                  "isNamedColor": {
                    "type": "boolean"
                  },
                  "isSystemColor": {
                    "type": "boolean"
                  },
                  "name": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                },
                "additionalProperties": false
              },
              "title": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "seriesType": {
                "enum": [
                  "Point",
                  "Line",
                  "PointArea",
                  "LineArea"
                ],
                "type": "string",
                "x-enum-map": {
                  "Point": 0,
                  "Line": 1,
                  "PointArea": 2,
                  "LineArea": 3
                }
              },
              "markerShape": {
                "enum": [
                  "Circle",
                  "None",
                  "Hexagon",
                  "InverseTriangle",
                  "Pentagon",
                  "Square",
                  "Star",
                  "7",
                  "-1"
                ],
                "type": "string",
                "x-enum-map": {
                  "Circle": 0,
                  "None": 1,
                  "Hexagon": 2,
                  "InverseTriangle": 3,
                  "Pentagon": 4,
                  "Square": 5,
                  "Star": 6
                }
              },
              "markerSize": {
                "type": "integer",
                "format": "int32"
              },
              "markersVisible": {
                "type": "boolean"
              },
              "lineThickness": {
                "type": "integer",
                "format": "int32"
              },
              "lineStyle": {
                "enum": [
                  "Dashed",
                  "DotDashed",
                  "Dotted",
                  "Solid"
                ],
                "type": "string",
                "x-enum-map": {
                  "Dashed": 0,
                  "DotDashed": 1,
                  "Dotted": 2,
                  "Solid": 3
                }
              },
              "smooth": {
                "type": "boolean"
              },
              "fillTitle": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "fillDirection": {
                "enum": [
                  "Up",
                  "Down"
                ],
                "type": "string",
                "x-enum-map": {
                  "Up": 0,
                  "Down": 1
                }
              }
            },
            "additionalProperties": false
          },
          "points": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "object",
              "properties": {
                "x": {
                  "type": "number",
                  "format": "double"
                },
                "y": {
                  "type": "number",
                  "format": "double"
                },
                "z": {
                  "type": "number",
                  "format": "double"
                }
              },
              "additionalProperties": false
            }
          },
          "minX": {
            "type": "number",
            "format": "double"
          },
          "maxX": {
            "type": "number",
            "format": "double"
          },
          "minY": {
            "type": "number",
            "format": "double"
          },
          "maxY": {
            "type": "number",
            "format": "double"
          },
          "minZ": {
            "type": "number",
            "format": "double"
          },
          "maxZ": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    },
    "defaultOptions": {
      "type": "object",
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "subTitle": {
          "type": [
            "string",
            "null"
          ]
        },
        "subSubTitle": {
          "type": [
            "string",
            "null"
          ]
        },
        "legendPlacementHorizontal": {
          "enum": [
            "LeftOutside",
            "Left",
            "Center",
            "Right",
            "RightOutside"
          ],
          "type": "string",
          "x-enum-map": {
            "LeftOutside": 0,
            "Left": 1,
            "Center": 2,
            "Right": 3,
            "RightOutside": 4
          }
        },
        "legendPlacementVertical": {
          "enum": [
            "TopOutside",
            "Top",
            "Center",
            "Bottom",
            "BottomOutside"
          ],
          "type": "string",
          "x-enum-map": {
            "TopOutside": 0,
            "Top": 1,
            "Center": 2,
            "Bottom": 3,
            "BottomOutside": 4
          }
        },
        "tickCountX": {
          "type": "integer",
          "format": "int32"
        },
        "tickCountY": {
          "type": "integer",
          "format": "int32"
        },
        "allowZoom": {
          "type": "boolean"
        },
        "allowScroll": {
          "type": "boolean"
        },
        "visualRangeMinX": {
          "type": "number",
          "format": "double"
        },
        "visualRangeMaxX": {
          "type": "number",
          "format": "double"
        },
        "showCrosshairX": {
          "type": "boolean"
        },
        "showCrosshairLableX": {
          "type": "boolean"
        },
        "showCrosshairY": {
          "type": "boolean"
        },
        "showCrosshairLableY": {
          "type": "boolean"
        },
        "axisTitleX": {
          "type": [
            "string",
            "null"
          ]
        },
        "axisTitleY": {
          "type": [
            "string",
            "null"
          ]
        },
        "maxDecimalPlacesX": {
          "type": "integer",
          "format": "int32"
        },
        "maxDecimalPlacesY": {
          "type": "integer",
          "format": "int32"
        },
        "visualRangeMinY": {
          "type": "number",
          "format": "double"
        },
        "visualRangeMaxY": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false
    }
  }
}
