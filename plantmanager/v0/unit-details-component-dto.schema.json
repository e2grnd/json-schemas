{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/unit-details-component-dto.schema.json",
  "title": "UnitDetailsComponentDto",
  "type": "object",
  "additionalProperties": false,
  "properties": {
