    "name": {
      "type": [
        "string",
        "null"
      ]
    },
    "rbi": {
      "type": "boolean"
    },
    "riskCategory": {
      "type": [
        "string",
        "null"
      ]
    },
    "riskColor": {
      "type": [
        "string",
        "null"
      ]
    },
    "type": {
      "type": [
        "string",
        "null"
      ]
    },
    "size": {
      "type": [
        "string",
        "null"
      ]
    },
    "nominalThickness": {
      "type": [
        "string",
        "null"
      ]
    },
    "material": {
      "type": [
        "string",
        "null"
      ]
    },
    "corrosionAllowance": {
      "type": [
        "string",
        "null"
      ]
    },
    "minimumThickness": {
      "type": [
        "string",
        "null"
      ]
    },
    "maximumAllowableWorkingPressure": {
      "type": [
        "number",
        "null"
      ],
      "format": "double"
    },
    "conditionMonitoringLocationsCount": {
      "type": [
        "integer",
        "null"
      ],
      "format": "int32"
