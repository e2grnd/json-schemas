{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/chart-display-options-xy.schema.json",
  "title": "ChartDisplayOptionsXY",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "subTitle": {
      "type": [
        "string",
        "null"
      ]
    },
    "subSubTitle": {
      "type": [
        "string",
        "null"
      ]
    },
    "titleColor": {
      "type": "object",
      "properties": {
        "r": {
          "type": "integer",
          "format": "int32"
        },
        "g": {
          "type": "integer",
          "format": "int32"
        },
        "b": {
          "type": "integer",
          "format": "int32"
        },
        "a": {
          "type": "integer",
          "format": "int32"
        },
        "isKnownColor": {
          "type": "boolean"
        },
        "isEmpty": {
          "type": "boolean"
        },
        "isNamedColor": {
          "type": "boolean"
        },
        "isSystemColor": {
          "type": "boolean"
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "legendPlacementHorizontal": {
      "enum": [
        "LeftOutside",
        "Left",
        "Center",
        "Right",
        "RightOutside"
      ],
      "type": "string",
      "x-enum-map": {
        "LeftOutside": 0,
        "Left": 1,
        "Center": 2,
        "Right": 3,
        "RightOutside": 4
      }
    },
    "legendPlacementVertical": {
      "enum": [
        "TopOutside",
        "Top",
        "Center",
        "Bottom",
        "BottomOutside"
      ],
      "type": "string",
      "x-enum-map": {
        "TopOutside": 0,
        "Top": 1,
        "Center": 2,
        "Bottom": 3,
        "BottomOutside": 4
      }
    },
    "tickCountX": {
      "type": "integer",
      "format": "int32"
    },
    "tickCountY": {
      "type": "integer",
      "format": "int32"
    },
    "allowZoom": {
      "type": "boolean"
    },
    "allowScroll": {
      "type": "boolean"
    },
    "visualRangeMinX": {
      "type": "number",
      "format": "double"
    },
    "visualRangeMaxX": {
      "type": "number",
      "format": "double"
    },
    "showCrosshairX": {
      "type": "boolean"
    },
    "showCrosshairLableX": {
      "type": "boolean"
    },
    "showCrosshairY": {
      "type": "boolean"
    },
    "showCrosshairLableY": {
      "type": "boolean"
    },
    "axisTitleX": {
      "type": [
        "string",
        "null"
      ]
    },
    "axisTitleY": {
      "type": [
        "string",
        "null"
      ]
    },
    "maxDecimalPlacesX": {
      "type": "integer",
      "format": "int32"
    },
    "maxDecimalPlacesY": {
      "type": "integer",
      "format": "int32"
    },
    "visualRangeMinY": {
      "type": "number",
      "format": "double"
    },
    "visualRangeMaxY": {
      "type": "number",
      "format": "double"
    }
  }
}
