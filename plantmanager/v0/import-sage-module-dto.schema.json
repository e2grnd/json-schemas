      ]
    },
    "userKey": {
      "type": [
        "string",
        "null"
      ]
    },
    "attachments": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "blobId": {
            "type": [
              "string",
              "null"
            ]
          },
          "fileName": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
