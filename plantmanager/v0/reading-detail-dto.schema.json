    "isBaseline": {
      "type": "boolean"
    },
    "surveyId": {
      "type": "string",
      "format": "uuid"
    },
    "excludeFromCalculation": {
      "type": "boolean"
    },
    "cmlId": {
      "type": "string",
      "format": "uuid"
    },
    "date": {
