        "null"
      ],
      "format": "uuid"
    },
    "thickness": {
      "type": [
        "number",
        "null"
      ],
      "format": "double"
    },
    "thicknessComment": {
      "type": [
        "string",
        "null"
      ]
    },
    "origMeasThickness": {
      "type": [
        "number",
        "null"
      ],
      "format": "double"
    },
    "inspectionMethod": {
      "enum": [
        "UNKOWN",
        "UT",
        "RT",
        "N",
        "I",
        "S",
        "H",
        "D",
        "C",
        "P",
        "V",
        "Y",
        "M"
      ],
      "type": "string",
      "x-enum-map": {
        "UNKOWN": 0,
        "UT": 1,
        "RT": 2,
        "N": 3,
        "I": 4,
        "S": 5,
        "H": 6,
        "D": 7,
        "C": 8,
        "P": 9,
        "V": 10,
        "Y": 11,
        "M": 12
      }
