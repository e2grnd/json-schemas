{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/reading-detail-dto.schema.json",
  "title": "ReadingDetailDto",
  "type": "object",
  "additionalProperties": false,
