{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/user-hierarchy-permissions-update-dto.schema.json",
  "title": "UserHierarchyPermissionsUpdateDto",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "users": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "userKey": {
            "type": [
              "string",
              "null"
            ]
          },
          "assetTypes": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "enum": [
                "AirCooler",
                "Boiler",
                "Compressor",
                "FiredHeater",
                "HorizontalVessel",
                "PipingSystem",
                "PressureReliefDevice",
                "Pump",
                "ShellTubeHeatExchanger",
                "Sphere",
                "StorageTank",
                "VerticalVessel",
                "Other"
              ],
              "type": "string",
              "x-enum-map": {
                "AirCooler": 1,
                "Boiler": 2,
                "Compressor": 3,
                "FiredHeater": 4,
                "HorizontalVessel": 5,
                "PipingSystem": 6,
                "PressureReliefDevice": 7,
                "Pump": 8,
                "ShellTubeHeatExchanger": 9,
                "Sphere": 10,
                "StorageTank": 11,
                "VerticalVessel": 12,
                "Other": 13
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "hierarchyPermissions": {
      "type": "object",
      "properties": {
        "plants": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "defaultEdit": {
                "type": "boolean"
              },
              "defaultAdmin": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "units": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "canEdit": {
                "type": "boolean"
              },
              "isAdmin": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "canManageRoles": {
      "type": "boolean"
    }
  }
