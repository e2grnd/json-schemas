{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/cml-default-values.schema.json",
  "title": "CmlDefaultValues",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "asset": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "assetId": {
            "type": "string",
            "format": "uuid"
          },
          "maximumInterval": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32"
          },
          "accessLimitations": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "component": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "componentId": {
            "type": "string",
            "format": "uuid"
          },
          "inServiceDate": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "circuitId": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "insulationType": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  }
}
