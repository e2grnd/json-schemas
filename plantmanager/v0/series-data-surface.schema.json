{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/series-data-surface.schema.json",
  "title": "SeriesDataSurface",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "defaultConfig": {
      "type": "object",
      "properties": {
        "visible": {
          "type": "boolean"
        },
        "showInLegend": {
          "type": "boolean"
        },
        "color": {
          "type": "object",
          "properties": {
            "r": {
              "type": "integer",
              "format": "int32"
            },
            "g": {
              "type": "integer",
              "format": "int32"
            },
            "b": {
              "type": "integer",
              "format": "int32"
            },
            "a": {
              "type": "integer",
              "format": "int32"
            },
            "isKnownColor": {
              "type": "boolean"
            },
            "isEmpty": {
              "type": "boolean"
            },
            "isNamedColor": {
              "type": "boolean"
            },
            "isSystemColor": {
              "type": "boolean"
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "points": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "x": {
            "type": "number",
            "format": "double"
          },
          "y": {
            "type": "number",
            "format": "double"
          },
          "z": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    },
    "minX": {
      "type": "number",
      "format": "double"
    },
    "maxX": {
      "type": "number",
      "format": "double"
    },
    "minY": {
      "type": "number",
      "format": "double"
    },
    "maxY": {
      "type": "number",
      "format": "double"
    },
    "minZ": {
      "type": "number",
      "format": "double"
    },
    "maxZ": {
      "type": "number",
      "format": "double"
    },
    "surfaceCells": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "enum": [
              "Quadrilateral",
              "Triangle",
              "Functional"
            ],
            "type": "string",
            "x-enum-map": {
              "Quadrilateral": 0,
              "Triangle": 1,
              "Functional": 2
            }
          },
          "pointIds": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "integer",
              "format": "int32"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "displacementPoints": {
      "type": [
        "array",
        "null"
      ]
    },
    "scalars": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "data": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "number",
              "format": "double"
            }
          },
          "count": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    },
    "yCount": {
      "type": "integer",
      "format": "int32"
    },
    "xCount": {
      "type": "integer",
      "format": "int32"
    }
  }
}
