{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://e2grnd.github.io/json-schemas/plantmanager/v0/chart-display-options-surface.schema.json",
  "title": "ChartDisplayOptionsSurface",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "subTitle": {
      "type": [
        "string",
        "null"
      ]
    },
    "subSubTitle": {
      "type": [
        "string",
        "null"
      ]
    },
    "titleColor": {
      "type": "object",
      "properties": {
        "r": {
          "type": "integer",
          "format": "int32"
        },
        "g": {
          "type": "integer",
          "format": "int32"
        },
        "b": {
          "type": "integer",
          "format": "int32"
        },
        "a": {
          "type": "integer",
          "format": "int32"
        },
        "isKnownColor": {
          "type": "boolean"
        },
        "isEmpty": {
          "type": "boolean"
        },
        "isNamedColor": {
          "type": "boolean"
        },
        "isSystemColor": {
          "type": "boolean"
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "legendPlacementHorizontal": {
      "enum": [
        "LeftOutside",
        "Left",
        "Center",
        "Right",
        "RightOutside"
      ],
      "type": "string",
      "x-enum-map": {
        "LeftOutside": 0,
        "Left": 1,
        "Center": 2,
        "Right": 3,
        "RightOutside": 4
      }
    },
    "legendPlacementVertical": {
      "enum": [
        "TopOutside",
        "Top",
        "Center",
        "Bottom",
        "BottomOutside"
      ],
      "type": "string",
      "x-enum-map": {
        "TopOutside": 0,
        "Top": 1,
        "Center": 2,
        "Bottom": 3,
        "BottomOutside": 4
      }
    },
    "tickCountX": {
      "type": "integer",
      "format": "int32"
    },
    "tickCountY": {
      "type": "integer",
      "format": "int32"
    },
    "allowZoom": {
      "type": "boolean"
    },
    "allowScroll": {
      "type": "boolean"
    },
    "axisTitleX": {
      "type": [
        "string",
        "null"
      ]
    },
    "axisTitleY": {
      "type": [
        "string",
        "null"
      ]
    },
    "axisTitleZ": {
      "type": [
        "string",
        "null"
      ]
    },
    "displayGroupName": {
      "type": [
        "string",
        "null"
      ]
    },
    "drawGridLinesX": {
      "type": "boolean"
    },
    "drawGridLinesY": {
      "type": "boolean"
    },
    "drawGridLinesZ": {
      "type": "boolean"
    },
    "showTitle": {
      "type": "boolean"
    },
    "showAxesLabels": {
      "type": "boolean"
    },
    "showScaleBar": {
      "type": "boolean"
    },
    "showContourLines": {
      "type": "boolean"
    },
    "numberContourLines": {
      "type": "integer",
      "format": "int32"
    },
    "viewDirection": {
      "enum": [
        "Top",
        "XSide",
        "YSide",
        "Skew"
      ],
      "type": "string",
      "x-enum-map": {
        "Top": 0,
        "XSide": 1,
        "YSide": 2,
        "Skew": 3
      }
    },
    "deformationScaleFactor": {
      "type": "number",
      "format": "double"
    },
    "zoomAmount": {
      "type": "number",
      "format": "double"
    },
    "focalPoint": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number",
          "format": "double"
        },
        "y": {
          "type": "number",
          "format": "double"
        },
        "z": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false
    },
    "scalarDisplayOptions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "units": {
            "type": [
              "string",
              "null"
            ]
          },
          "format": {
            "type": [
              "string",
              "null"
            ]
          },
          "visible": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
